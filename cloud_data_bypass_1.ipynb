# -*- coding: utf-8 -*-
"""Cloud Data Bypass Pipeline: Google Drive to AWS S3 Glacier

This script provides a high-speed, server-to-server data pipeline utilizing 
Google Colab's Linux backend to transfer massive datasets directly to AWS S3 
without consuming local network bandwidth.
"""

# ==========================================
# STEP 1: Mount Environment & Install Tools
# ==========================================
from google.colab import drive
drive.mount('/content/drive')

# Install the AWS Command Line Interface
!pip install awscli

# Configure AWS Credentials (Prompts for Access Key, Secret Key, and Region)
!aws configure

# ==========================================
# STEP 2: Method A - Direct Directory Transfer
# Use this for transferring pre-packaged files or standard directories.
# ==========================================

# Standard recursive copy to AWS Deep Archive
!aws s3 cp "/content/drive/MyDrive/YOUR_SOURCE_FOLDER_1" s3://YOUR_BUCKET_NAME/target_folder_1 --recursive --storage-class DEEP_ARCHIVE
!aws s3 cp "/content/drive/MyDrive/YOUR_SOURCE_FOLDER_2" s3://YOUR_BUCKET_NAME/target_folder_2 --recursive --storage-class DEEP_ARCHIVE

# ==========================================
# STEP 3: Method B - The "Zip-on-the-Fly" Transfer
# Use this for thousands of loose files. This leverages the Colab VM's 
# temporary scratch disk to compress files before transfer, heavily 
# optimizing the AWS S3 upload speed and minimizing API calls.
# ==========================================

# 1. Zip the loose directory and save it to Colab's temporary local storage
!zip -r /content/optimized_archive.zip "/content/drive/MyDrive/YOUR_LOOSE_FILES_FOLDER"

# 2. Blast the compressed archive to the specific subfolder in the AWS vault
!aws s3 cp /content/optimized_archive.zip s3://YOUR_BUCKET_NAME/archive_destination/optimized_archive.zip --storage-class DEEP_ARCHIVE

# 3. Delete the local zip to free up the Colab server's memory for the next batch
!rm /content/optimized_archive.zip
